# ==============================================================================
# SEA Team Lead — Environment Variables
# Copy this file to .env and fill in your values.
# ==============================================================================

# --- Google Gemini API (required) ---
# Get your key from https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=

# --- MongoDB Atlas (optional, enables persistence) ---
# Without this the agents still work but don't persist results across sessions.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true
MDB_MCP_CONNECTION_STRING=

# --- Firebase Auth (optional, enables user login) ---
# Get these from https://console.firebase.google.com/ -> Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Security / CORS (optional) ---
# Restrict CORS allowed origins (comma-separated). If unset, ADK defaults apply.
# ALLOW_ORIGINS=https://your-frontend.example.com
# Frontend origin for OAuth postMessage (restricts postMessage target).
# FRONTEND_ORIGIN=https://your-frontend.example.com

# --- Google Ads API (optional, enables live campaign creation) ---
# Without these the Campaign Builder runs in mock mode (simulates everything).
# Set up via Settings page OAuth flow or manually here:
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# GOOGLE_ADS_CUSTOMER_ID=
